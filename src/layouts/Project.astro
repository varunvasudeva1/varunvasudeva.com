---
title: "Project";
description: "A project card, used to display a software engineering/data science project on the /code page.";

import Card from "./Card.astro";

export interface Props {
  title: string;
  description: string;
  link?: string;
  linkText?: string;
  buttonLink?: string;
  buttonLinkText?: string;
  image?: string;
}

const {
  title,
  description,
  link,
  linkText,
  buttonLink,
  buttonLinkText,
  image,
} = Astro.props as Props;
---

<Card className="flex-col items-start justify-center p-5 m-2">
  {
    image && (
      <img
        class="w-full object-contain rounded-lg"
        src={image}
        alt={title + ": " + description}
      />
    )
  }
  <span class="m-5">
    <span class="flex-row flex items-baseline space-x-2">
      <h1 class="font-sans text-xl sm:text-2xl font-bold text-white">
        {title}
      </h1>
      {
        link && (
          <a class="text-purple-300 text-base font-mono" href={link}>
            {linkText || "View on GitHub"}
          </a>
        )
      }
    </span>
    <p class="font-sans text-base sm:text-lg text-white">{description}</p>
    {
      buttonLink && (
        <a
          class="font-mono bg-purple-300 text-purple-900 hover:bg-opacity-80 hover:text-white text-sm font-semibold p-4 mt-5 rounded-full flex text-center items-center justify-center self-center"
          href={buttonLink}
        >
          {buttonLinkText || "Learn More"}
        </a>
      )
    }
  </span>
</Card>
