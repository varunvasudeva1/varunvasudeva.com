---
title: "Project";
description: "A project card, used to display a software engineering/data science project on the /code page.";

import Card from "./Card.astro";

export interface Props {
  title: string;
  description: string;
  link?: string;
  linkText?: string;
  image?: string;
}

const { title, description, link, linkText, image } = Astro.props as Props;
---

<Card className="flex-col items-start justify-center w-3/4">
  {
    image && (
      <img
        class="w-full h-full object-contain mb-5"
        src={image}
        alt={title + ": " + description}
      />
    )
  }
  <h1 class="font-sans text-2xl font-bold text-white mb-2">{title}</h1>
  <p class="font-sans text-lg text-white">{description}</p>
  {
    link && (
      <a
        class="font-mono bg-purple-300 text-purple-900 text-sm font-semibold p-4 mt-5 rounded-full flex text-center items-center justify-center self-center"
        href={link}
      >
        {linkText || "Learn More"}
      </a>
    )
  }
</Card>
