---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import NavBar from "../components/NavBar.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../config";

const { title }: { title?: string } = Astro.props;
const background =
  title === "Home"
    ? "src/images/home.jpg"
    : title === "Code"
    ? "src/images/code.jpg"
    : title === "Music"
    ? "src/images/music.jpg"
    : title === "Articles"
    ? "src/images/articles.jpg"
    : "src/images/home.jpg";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-gray-900">
    <img
      src={background}
      alt={title ? title : "" + " background"}
      class="fixed -z-20 inset-0 w-full h-full object-cover"
    />
    <div
      class="fixed -z-10 inset-0 w-full h-full object-cover backdrop-blur-md bg-black bg-opacity-10"
    >
    </div>
    <NavBar />
    <main>
      <slot />
      <Footer />
    </main>
  </body>
</html>
