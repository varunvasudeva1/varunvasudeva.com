---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import NavBar from "../components/NavBar.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../config";

const { title }: { title?: string } = Astro.props;
const background =
  title === "Home"
    ? "transparent"
    : title === "Code"
    ? "from-red-900 to-amber-700"
    : title === "Music"
    ? "from-fuchsia-900 to-rose-700"
    : title === "Articles"
    ? "from-emerald-900 to-cyan-700"
    : "transparent";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-slate-950">
    <NavBar title={title} />
    <main
      class={`bg-gradient-to-br ${background} w-full min-h-screen z-0 pt-20`}
    >
      <h1 class="text-5xl md:text-6xl font-bold text-white pt-4 px-8">
        {title}.
      </h1>
      <slot />
      <Footer />
    </main>
  </body>
</html>
