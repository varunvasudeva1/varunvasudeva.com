---
export interface Props extends astroHTML.JSX.AnchorHTMLAttributes {}

const { href, class: className, ...props } = Astro.props;

const { pathname } = Astro.url;
const isActive = href === pathname || href === pathname.replace(/\/$/, "");
---

<a
  href={href}
  class={`font-sans text-sm lg:text-md font-semibold py-1 px-2 lg:px-3 bg-opacity-20 rounded-full text-purple-200 hover:text-purple-400 ${
    isActive ? "bg-gray-400 bg-opacity-20 text-purple-300" : ""
  }`}
  {...props}><slot /></a
>
