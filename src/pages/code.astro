---
import Card from "../layouts/Card.astro";
import Page from "../layouts/Page.astro";
import Project from "../layouts/Project.astro";
import { BsCloudFill, BsFillTerminalFill } from "react-icons/bs/index";
import { BiNetworkChart } from "react-icons/bi/index";
import { FaRegHandshake } from "react-icons/fa/index";
---

<Page title="Code">
  <section class="flex flex-col items-center justify-center my-10 mx-5">
    <Card
      className="flex flex-col items-center justify-center p-4 max-w-3xl border-gray-200 border border-opacity-40"
    >
      <div class="flex flex-col flex-wrap items-center justify-center mb-5">
        <h1
          class="text-3xl lg:text-4xl text-white font-bold transition-all duration-200"
        >
          Software Engineer
        </h1>
        <FaRegHandshake
          className="text-5xl lg:text-6xl text-white mx-3 transition-all duration-200"
        />
        <h1
          class="text-3xl lg:text-4xl text-white font-bold transition-all duration-200"
        >
          Data Scientist
        </h1>
      </div>
      <div class="border-b border-gray-200 w-full mb-5"></div>
      <div class="grid grid-cols-1 gap-3 md:grid-cols-3 lg:gap-5">
        <div class="flex flex-col items-start">
          <BsFillTerminalFill className="w-10 h-10 text-white" />
          <h2
            class="text-xl lg:text-2xl text-white font-semibold mt-2 transition-all duration-200"
          >
            Full Stack
          </h2>
          <p class="text-gray-300">
            Extensive experience building full-stack mobile & web applications
            using an array of technologies
          </p>
        </div>
        <div class="flex flex-col items-start">
          <BiNetworkChart className="w-10 h-10 text-white" />
          <h2
            class="text-xl lg:text-2xl text-white font-semibold mt-2 transition-all duration-200"
          >
            Machine Learning
          </h2>
          <p class="text-gray-300">
            Proficiency building and using SoTA machine learning models for a
            variety of applications
          </p>
        </div>
        <div class="flex flex-col items-start">
          <BsCloudFill className="w-10 h-10 text-white" />
          <h2
            class="text-xl lg:text-2xl transition-all duration-200 text-white font-semibold mt-2"
          >
            Cloud Computing
          </h2>
          <p class="text-gray-300">
            Demonstrated expertise in building and deploying applications on
            cloud platforms
          </p>
        </div>
      </div>
    </Card>
    <div class="grid grid-cols-1 lg:grid-cols-2 mt-4">
      <div>
        <h2 class="text-xl lg:text-2xl text-white font-semibold mt-2">
          Languages
        </h2>
        <div class="flex flex-row flex-wrap justify-center icon-container py-4">
          <div
            class="flex flex-col justify-start items-center backdrop-blur-lg bg-slate-800 bg-opacity-60 p-8 m-2"
          >
            <p class="text-md lg:text-lg font-semibold text-gray-300 mb-3">
              TypeScript
            </p>
            <img
              src="/images/logos/typescript-logo.png"
              alt="TypeScript"
              class="w-24 h-24 md:w-32 md:h-32 transition-all duration-300 ease-in-out"
            />
          </div>
          <div
            class="flex flex-col justify-start items-center backdrop-blur-lg bg-slate-800 bg-opacity-60 p-8 m-2"
          >
            <p class="text-md lg:text-lg font-semibold text-gray-300 mb-3">
              Python
            </p>
            <img
              src="/images/logos/python-logo.png"
              alt="Python"
              class="w-24 h-24 md:w-32 md:h-32 transition-all duration-300 ease-in-out"
            />
          </div>
          <div
            class="flex flex-col justify-start items-center backdrop-blur-lg bg-slate-800 bg-opacity-60 p-8 m-2"
          >
            <p class="text-md lg:text-lg font-semibold text-gray-300 mb-3">
              Java
            </p>
            <img
              src="/images/logos/java-logo.png"
              alt="Java"
              class="w-24 h-24 md:w-32 md:h-32 transition-all duration-300 ease-in-out"
            />
          </div>
        </div>
      </div>

      <div>
        <h2 class="text-xl lg:text-2xl text-white font-semibold mt-2">
          Frameworks
        </h2>
        <div class="flex flex-row flex-wrap justify-center icon-container py-4">
          <div
            class="flex flex-col justify-start items-center backdrop-blur-lg bg-slate-800 bg-opacity-60 p-8 m-2"
          >
            <p class="text-md lg:text-lg font-semibold text-gray-300 mb-3">
              React
            </p>
            <img
              src="/images/logos/react-logo.png"
              alt="React and React Native"
              class="w-24 h-24 md:w-32 md:h-32 transition-all duration-300 ease-in-out object-contain"
            />
          </div>
          <div
            class="flex flex-col justify-start items-center backdrop-blur-lg bg-slate-800 bg-opacity-60 p-8 m-2"
          >
            <p class="text-md lg:text-lg font-semibold text-gray-300 mb-3">
              NextJS
            </p>
            <img
              src="/images/logos/nextjs-logo.png"
              alt="NextJS"
              class="w-24 h-24 md:w-32 md:h-32 transition-all duration-300 ease-in-out"
            />
          </div>
          <div
            class="flex flex-col justify-start items-center backdrop-blur-lg bg-slate-800 bg-opacity-60 p-8 m-2"
          >
            <p class="text-md lg:text-lg font-semibold text-gray-300 mb-3">
              Astro
            </p>
            <img
              src="/images/logos/astro-logo.png"
              alt="Astro"
              class="w-24 h-24 md:w-32 md:h-32 transition-all duration-300 ease-in-out"
            />
          </div>
          <div
            class="flex flex-col justify-start items-center backdrop-blur-lg bg-slate-800 bg-opacity-60 p-8 m-2"
          >
            <p class="text-md lg:text-lg font-semibold text-gray-300 mb-3">
              TailwindCSS
            </p>
            <img
              src="/images/logos/tailwind-logo.png"
              alt="TailwindCSS"
              class="w-24 h-24 md:w-32 md:h-32 transition-all duration-300 ease-in-out object-contain"
            />
          </div>
        </div>
      </div>

      <div>
        <h2 class="text-xl lg:text-2xl text-white font-semibold mt-2">Tools</h2>
        <div class="flex flex-row flex-wrap justify-center icon-container py-4">
          <div
            class="flex flex-col justify-start items-center backdrop-blur-lg bg-slate-800 bg-opacity-60 p-8 m-2"
          >
            <p class="text-md lg:text-lg font-semibold text-gray-300 mb-3">
              Git
            </p>
            <img
              src="/images/logos/git-logo.png"
              alt="Git"
              class="w-24 h-24 md:w-32 md:h-32 transition-all duration-300 ease-in-out object-contain"
            />
          </div>
          <div
            class="flex flex-col justify-start items-center backdrop-blur-lg bg-slate-800 bg-opacity-60 p-8 m-2"
          >
            <p class="text-md lg:text-lg font-semibold text-gray-300 mb-3">
              Figma
            </p>
            <img
              src="/images/logos/figma-logo.png"
              alt="Figma"
              class="w-24 h-24 md:w-32 md:h-32 transition-all duration-300 ease-in-out object-contain"
            />
          </div>
        </div>
      </div>
    </div>
    {/* Showcase */}
    <section class="flex flex-col items-center justify-center m-5">
      <h1
        class="text-2xl lg:text-3xl text-white font-bold mb-5 transition-all duration-200"
      >
        Recent Projects
      </h1>
      <div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
        <Project
          title="Launchpad"
          description="A web app that allows users to centralize their tech project's resources, such as links, files, and notes, in one place. Launchpad also features an easy-to-use questionnaire powered by GPT-3.5 that suggests stack tools. Users can also share their projects with others, allowing for easy collaboration."
          image="images/launchpad-icon.png"
          buttonLink="https://launchpad-2023.vercel.app"
          buttonLinkText="Go to Launchpad"
        />
        <Project
          title="Archive"
          description="A highly personalizable, AI-powered journaling app that allows users to record their thoughts, feelings, and memories. Archive uses natural language processing to analyze logs and provide insights on their sentiments. It also features full-text search over entries, allowing users to access their logs quickly and easily."
          image="images/archive-app-icon.png"
          link="https://archiveapp.io"
          linkText="archiveapp.io"
          buttonLink="https://apps.apple.com/us/app/archive-ai-powered-journaling/id1615879510"
          buttonLinkText="Download on the App Store"
        />
        <Project
          title="Predicting Electron Mass Using Neural Networks"
          description="A neural network that takes tabular data, collected at CERN's Large Hadron Collider and made available on Kaggle, such as electron spin, position, charge, etc. of a pair of electrons as input and predicts the invariant mass of the electron pair."
          image="images/cern-lhc.jpg"
          buttonLink="https://github.com/varunvasudeva1/cern-ec"
          buttonLinkText="View on GitHub"
        />
      </div>
    </section>
  </section>
</Page>
