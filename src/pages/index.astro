---
import BaseHead from "../components/BaseHead.astro";
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../config";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-gray-900">
    <NavBar />
    <main class="flex flex-col items-flex-start justify-center h-full">
      <section
        class="flex flex-col items-start justify-center my-10 w-full h-full"
      >
        <h1 class="font-sans text-8xl font-bold text-white">Hi, I'm Varun.</h1>
        <h1 class="font-sans text-6xl font-bold text-white">
          I design & build <span
            class="bg-gradient-to-r from-cyan-500 to-purple-300 bg-clip-text text-transparent"
            >reliable, scalable & performant
          </span>
          software.
        </h1>
      </section>

      <p1 class="font-mono text-lg text-white"> New!</p1>
      <section
        class="flex flex-row items-center justify-center mb-10 w-full h-full bg-slate-800 rounded-lg p-10 shadow-xl"
      >
        <img class="w-1/3 h-1/3" src="src/images/archive-logo.png" />
        <div class="flex flex-col items-start justify-center mx-5 space-y-3">
          <div class="flex flex-row items-baseline justify-center space-x-3">
            <h1 class="font-sans text-2xl font-bold text-white">Archive</h1>
            <a
              class="text-purple-300 text-base font-mono"
              href="https://archiveapp.io">archiveapp.io</a
            >
          </div>
          <p class="font-sans text-base text-white">
            A highly personalizable, AI-powered journaling app that allows users
            to record their thoughts, feelings, and memories. Archive uses
            natural language processing to analyze logs and provide insights on
            their sentiments. It also features full-text search over entries,
            allowing users to access their logs quickly and easily.
          </p>
          <a
            class="font-mono bg-purple-300 text-purple-900 text-sm font-semibold p-4 rounded-full flex text-center items-center justify-center"
            href="https://apps.apple.com/us/app/archive-ai-powered-journaling/id1615879510"
            >Download on the App Store</a
          >
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
